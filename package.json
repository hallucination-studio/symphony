{
  "name": "symphony",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22.21.0 <23",
    "npm": ">=10"
  },
  "workspaces": [
    "apps/conductor",
    "apps/podium-desktop",
    "packages/contracts",
    "packages/podium"
  ],
  "scripts": {
    "build": "npm run build -w @symphony/podium && npm run build -w @symphony/conductor && npm run build -w @symphony/podium-desktop",
    "typecheck": "npm run build -w @symphony/podium && npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "contracts:generate": "tsx packages/contracts/tools/generate.ts",
    "contracts:check": "tsx packages/contracts/tools/generate.ts --check",
    "contracts:validate:typescript": "tsx packages/contracts/tools/validate-typescript.ts",
    "test:architecture": "node --test tests/architecture/*.test.mjs",
    "test:contracts": "node --test tests/contracts/*.test.mjs",
    "test:host": "npm run test:host -w @symphony/podium-desktop --",
    "test:integration": "node --test tests/integration/*.test.mjs tests/integration/*/*.test.mjs",
    "e2e:doctor": "node tools/e2e/doctor.mjs",
    "test:e2e:runner": "node tools/e2e/run-with-timeout.mjs --timeout-ms 300000 -- node --test tests/e2e/*.test.mjs",
    "desktop-shell-smoke:build": "node tools/e2e/desktop-shell-build.mjs",
    "desktop-shell-smoke": "npm run desktop-shell-smoke:build && node tools/e2e/desktop-shell-smoke.mjs",
    "test:typescript": "npm test -w @symphony/podium && npm test -w @symphony/conductor && npm test -w @symphony/podium-desktop",
    "test": "npm run test:architecture && npm run test:contracts && npm run test:typescript && npm run test:integration",
    "package": "npm run package -w @symphony/podium-desktop"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "8.18.1",
    "@typescript-eslint/parser": "8.18.1",
    "eslint": "8.57.1",
    "tsx": "4.23.1",
    "typescript": "5.6.3"
  }
}
