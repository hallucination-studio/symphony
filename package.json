{
  "name": "symphony",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22.21.0 <23",
    "npm": ">=10"
  },
  "workspaces": [
    "apps/conductor",
    "apps/podium-desktop",
    "packages/contracts",
    "packages/podium"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "contracts:check": "npm run test:contracts",
    "test:architecture": "node --test tests/architecture/*.test.mjs",
    "test:contracts": "node --test tests/contracts/*.test.mjs",
    "test:host": "npm run test:host -w @symphony/podium-desktop --",
    "test:integration": "node --test tests/integration/*.test.mjs",
    "test:acceptance": "node --test tests/acceptance/*.test.mjs",
    "test:typescript": "npm test --workspaces --if-present",
    "test": "npm run test:architecture && npm run test:contracts && npm run test:typescript",
    "package": "npm run package -w @symphony/podium-desktop"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "8.18.1",
    "@typescript-eslint/parser": "8.18.1",
    "eslint": "8.57.1",
    "tsx": "4.23.1",
    "typescript": "5.6.3"
  }
}
