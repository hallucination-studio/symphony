{
  "version": 1,
  "scopes": {
    "control-profile": {
      "path_patterns": [
        "^packages/podium/src/internal/runtime-observations/",
        "^apps/podium-desktop/src/ui/WorkPage\\.tsx$"
      ],
      "paths": [],
      "symbols": {
        "CommandAcceptedResult": [],
        "CreateRootCommand": [],
        "HostCommandAccepted": [],
        "NextActionView": []
      }
    },
    "linear-boundary": {
      "path_patterns": [],
      "paths": [],
      "symbols": {
        "ConductorHeartbeat": [],
        "ConductorRuntimeReport": []
      }
    },
    "e2e": {
      "path_patterns": [
        "^tools/e2e/cleanup\\.mjs$",
        "^tests/e2e/(?:runner|quiesce)\\.test\\.mjs$"
      ],
      "paths": [],
      "symbols": {}
    },
    "agent-workflow": {
      "path_patterns": [
        "^apps/conductor/src/linear-dag/",
        "^apps/conductor/src/root-workflow/",
        "^apps/conductor/src/performer-stage-client/",
        "^apps/conductor/src/runtime-reporting/",
        "^apps/conductor/src/composition/ConductorCycleDelayPolicy\\.ts$",
        "^apps/conductor/src/composition/LinearRootStageDispatcher\\.ts$",
        "^apps/performer/src/performer/stage_execution/",
        "^apps/performer/src/performer/stage_protocol/",
        "^tests/e2e/conductor-serialized-workflow\\.test\\.mjs$",
        "^tests/e2e/target-workflow-",
        "^tests/integration/recovery/(?:cancel|stage)-recovery\\.test\\.mjs$",
        "^tools/e2e/serialized-workflow-boundary\\.mjs$",
        "^tools/e2e/target-workflow-"
      ],
      "paths": [],
      "symbols": {
        "ConductorRuntimeReporter": [],
        "LinearDagExecution": [],
        "RootWorkflowPolicy": [],
        "ShortProcessPerformerStageClient": [],
        "StageContextEnvelope": [],
        "StageOutcome": []
      }
    }
  }
}
