{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Symphony",
  "version": "0.1.0",
  "identifier": "com.symphony.podium",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Symphony",
        "width": 1180,
        "height": 760,
        "minWidth": 768,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["symphony"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
