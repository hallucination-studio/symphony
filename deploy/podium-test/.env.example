PODIUM_DOMAIN=podium-dev.example.com
PODIUM_IMAGE=ghcr.io/hallucination-studio/symphony-podium:beta
PODIUM_HTTP_BIND=0.0.0.0:80

PODIUM_BASE_URL=https://podium-dev.example.com
PODIUM_SESSION_COOKIE_NAME=podium_session
PODIUM_SECRET_KEY=replace-with-a-long-random-secret
PODIUM_DISABLE_TURNSTILE=0

LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
LINEAR_REDIRECT_URI=https://podium-dev.example.com/api/v1/linear/oauth/callback

POSTGRES_DB=podium
POSTGRES_USER=podium
POSTGRES_PASSWORD=replace-with-a-long-random-password
