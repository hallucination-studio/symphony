{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://symphony.local/contracts/agent-command.schema.json",
  "title": "Agent Command Protocol V1",
  "$defs": {
    "AgentCommandChannelMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol_version",
        "turn_id",
        "root_issue_id",
        "performer_id",
        "request_path",
        "response_path"
      ],
      "properties": {
        "protocol_version": { "$ref": "common.schema.json#/$defs/ProtocolVersion" },
        "turn_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "root_issue_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "performer_id": { "$ref": "common.schema.json#/$defs/OpaqueIdentifier" },
        "request_path": { "const": ".symphony/agent-command/request.fifo" },
        "response_path": { "const": ".symphony/agent-command/response.fifo" }
      }
    },
    "EmptyArgs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {}
    },
    "LinearReadArgs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["issue_id", "include"],
      "properties": {
        "issue_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "include": {
          "type": "array",
          "maxItems": 8,
          "items": { "enum": ["issue", "children", "comments", "relations"] }
        },
        "cursor": { "$ref": "common.schema.json#/$defs/OpaqueIdentifier" },
        "limit": { "type": "integer", "minimum": 1, "maximum": 100 }
      }
    },
    "CreateChildArgs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["parent_issue_id", "kind", "title", "description", "write_id", "expected_remote_version", "expected_git_head"],
      "properties": {
        "parent_issue_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "kind": { "enum": ["work", "human", "rework"] },
        "title": { "$ref": "common.schema.json#/$defs/ShortText" },
        "description": { "$ref": "common.schema.json#/$defs/BoundedText" },
        "write_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "expected_remote_version": { "$ref": "common.schema.json#/$defs/OpaqueIdentifier" },
        "expected_git_head": { "$ref": "common.schema.json#/$defs/Identifier" }
      }
    },
    "UpdateIssueArgs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["issue_id", "expected_remote_version", "expected_git_head"],
      "properties": {
        "issue_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "title": { "$ref": "common.schema.json#/$defs/ShortText" },
        "description": { "$ref": "common.schema.json#/$defs/BoundedText" },
        "expected_remote_version": { "$ref": "common.schema.json#/$defs/OpaqueIdentifier" },
        "expected_git_head": { "$ref": "common.schema.json#/$defs/Identifier" }
      }
    },
    "SetStatusArgs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["issue_id", "status", "expected_remote_version", "expected_git_head"],
      "properties": {
        "issue_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "status": { "$ref": "common.schema.json#/$defs/LinearIssueState" },
        "expected_remote_version": { "$ref": "common.schema.json#/$defs/OpaqueIdentifier" },
        "expected_git_head": { "$ref": "common.schema.json#/$defs/Identifier" }
      }
    },
    "SetAssigneeArgs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["issue_id", "assignee_id", "expected_remote_version", "expected_git_head"],
      "properties": {
        "issue_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "assignee_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "expected_remote_version": { "$ref": "common.schema.json#/$defs/OpaqueIdentifier" },
        "expected_git_head": { "$ref": "common.schema.json#/$defs/Identifier" }
      }
    },
    "SetLabelArgs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["issue_id", "label", "operation", "expected_remote_version", "expected_git_head"],
      "properties": {
        "issue_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "label": { "$ref": "common.schema.json#/$defs/ShortText" },
        "operation": { "enum": ["add", "remove"] },
        "expected_remote_version": { "$ref": "common.schema.json#/$defs/OpaqueIdentifier" },
        "expected_git_head": { "$ref": "common.schema.json#/$defs/Identifier" }
      }
    },
    "CreateCommentArgs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["issue_id", "body", "write_id", "expected_remote_version", "expected_git_head"],
      "properties": {
        "issue_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "body": { "$ref": "common.schema.json#/$defs/BoundedText" },
        "write_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "expected_remote_version": { "$ref": "common.schema.json#/$defs/OpaqueIdentifier" },
        "expected_git_head": { "$ref": "common.schema.json#/$defs/Identifier" }
      }
    },
    "GitDiffArgs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": { "$ref": "common.schema.json#/$defs/BoundedPath" },
        "staged": { "type": "boolean" }
      }
    },
    "GitChecksArgs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "check_names": {
          "type": "array",
          "maxItems": 32,
          "items": { "$ref": "common.schema.json#/$defs/ShortText" }
        }
      }
    },
    "GitCommitArgs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["issue_id", "expected_remote_version", "expected_head"],
      "properties": {
        "issue_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "expected_remote_version": { "$ref": "common.schema.json#/$defs/OpaqueIdentifier" },
        "expected_head": { "$ref": "common.schema.json#/$defs/Identifier" }
      }
    },
    "RootDeliverArgs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["expected_head", "expected_root_version"],
      "properties": {
        "expected_head": { "$ref": "common.schema.json#/$defs/Identifier" },
        "expected_root_version": { "$ref": "common.schema.json#/$defs/OpaqueIdentifier" }
      }
    },
    "AgentCommandRequest": {
      "oneOf": [
        { "$ref": "#/$defs/LinearReadCommand" },
        { "$ref": "#/$defs/CreateChildCommand" },
        { "$ref": "#/$defs/UpdateIssueCommand" },
        { "$ref": "#/$defs/SetStatusCommand" },
        { "$ref": "#/$defs/SetAssigneeCommand" },
        { "$ref": "#/$defs/SetLabelCommand" },
        { "$ref": "#/$defs/CreateCommentCommand" },
        { "$ref": "#/$defs/GitStatusCommand" },
        { "$ref": "#/$defs/GitDiffCommand" },
        { "$ref": "#/$defs/GitChecksCommand" },
        { "$ref": "#/$defs/GitCommitCommand" },
        { "$ref": "#/$defs/RootDeliverCommand" }
      ]
    },
    "LinearReadCommand": { "$ref": "#/$defs/LinearReadEnvelope" },
    "CreateChildCommand": { "$ref": "#/$defs/CreateChildEnvelope" },
    "UpdateIssueCommand": { "$ref": "#/$defs/UpdateIssueEnvelope" },
    "SetStatusCommand": { "$ref": "#/$defs/SetStatusEnvelope" },
    "SetAssigneeCommand": { "$ref": "#/$defs/SetAssigneeEnvelope" },
    "SetLabelCommand": { "$ref": "#/$defs/SetLabelEnvelope" },
    "CreateCommentCommand": { "$ref": "#/$defs/CreateCommentEnvelope" },
    "GitStatusCommand": { "$ref": "#/$defs/GitStatusEnvelope" },
    "GitDiffCommand": { "$ref": "#/$defs/GitDiffEnvelope" },
    "GitChecksCommand": { "$ref": "#/$defs/GitChecksEnvelope" },
    "GitCommitCommand": { "$ref": "#/$defs/GitCommitEnvelope" },
    "RootDeliverCommand": { "$ref": "#/$defs/RootDeliverEnvelope" },
    "LinearReadEnvelope": {
      "type": "object", "additionalProperties": false,
      "required": ["protocol_version", "request_id", "turn_id", "root_issue_id", "performer_id", "command", "args"],
      "properties": { "protocol_version": { "$ref": "common.schema.json#/$defs/ProtocolVersion" }, "request_id": { "$ref": "common.schema.json#/$defs/Identifier" }, "turn_id": { "$ref": "common.schema.json#/$defs/Identifier" }, "root_issue_id": { "$ref": "common.schema.json#/$defs/Identifier" }, "performer_id": { "$ref": "common.schema.json#/$defs/OpaqueIdentifier" }, "command": { "const": "linear.read" }, "args": { "$ref": "#/$defs/LinearReadArgs" } }
    },
    "CreateChildEnvelope": {
      "type": "object", "additionalProperties": false,
      "required": ["protocol_version", "request_id", "turn_id", "root_issue_id", "performer_id", "command", "args"],
      "properties": { "protocol_version": { "$ref": "common.schema.json#/$defs/ProtocolVersion" }, "request_id": { "$ref": "common.schema.json#/$defs/Identifier" }, "turn_id": { "$ref": "common.schema.json#/$defs/Identifier" }, "root_issue_id": { "$ref": "common.schema.json#/$defs/Identifier" }, "performer_id": { "$ref": "common.schema.json#/$defs/OpaqueIdentifier" }, "command": { "const": "linear.issue.create_child" }, "args": { "$ref": "#/$defs/CreateChildArgs" } }
    },
    "UpdateIssueEnvelope": {
      "type": "object", "additionalProperties": false,
      "required": ["protocol_version", "request_id", "turn_id", "root_issue_id", "performer_id", "command", "args"],
      "properties": { "protocol_version": { "$ref": "common.schema.json#/$defs/ProtocolVersion" }, "request_id": { "$ref": "common.schema.json#/$defs/Identifier" }, "turn_id": { "$ref": "common.schema.json#/$defs/Identifier" }, "root_issue_id": { "$ref": "common.schema.json#/$defs/Identifier" }, "performer_id": { "$ref": "common.schema.json#/$defs/OpaqueIdentifier" }, "command": { "const": "linear.issue.update" }, "args": { "$ref": "#/$defs/UpdateIssueArgs" } }
    },
    "SetStatusEnvelope": {
      "type": "object", "additionalProperties": false,
      "required": ["protocol_version", "request_id", "turn_id", "root_issue_id", "performer_id", "command", "args"],
      "properties": { "protocol_version": { "$ref": "common.schema.json#/$defs/ProtocolVersion" }, "request_id": { "$ref": "common.schema.json#/$defs/Identifier" }, "turn_id": { "$ref": "common.schema.json#/$defs/Identifier" }, "root_issue_id": { "$ref": "common.schema.json#/$defs/Identifier" }, "performer_id": { "$ref": "common.schema.json#/$defs/OpaqueIdentifier" }, "command": { "const": "linear.status.set" }, "args": { "$ref": "#/$defs/SetStatusArgs" } }
    },
    "SetAssigneeEnvelope": {
      "type": "object", "additionalProperties": false,
      "required": ["protocol_version", "request_id", "turn_id", "root_issue_id", "performer_id", "command", "args"],
      "properties": { "protocol_version": { "$ref": "common.schema.json#/$defs/ProtocolVersion" }, "request_id": { "$ref": "common.schema.json#/$defs/Identifier" }, "turn_id": { "$ref": "common.schema.json#/$defs/Identifier" }, "root_issue_id": { "$ref": "common.schema.json#/$defs/Identifier" }, "performer_id": { "$ref": "common.schema.json#/$defs/OpaqueIdentifier" }, "command": { "const": "linear.assignee.set" }, "args": { "$ref": "#/$defs/SetAssigneeArgs" } }
    },
    "SetLabelEnvelope": {
      "type": "object", "additionalProperties": false,
      "required": ["protocol_version", "request_id", "turn_id", "root_issue_id", "performer_id", "command", "args"],
      "properties": { "protocol_version": { "$ref": "common.schema.json#/$defs/ProtocolVersion" }, "request_id": { "$ref": "common.schema.json#/$defs/Identifier" }, "turn_id": { "$ref": "common.schema.json#/$defs/Identifier" }, "root_issue_id": { "$ref": "common.schema.json#/$defs/Identifier" }, "performer_id": { "$ref": "common.schema.json#/$defs/OpaqueIdentifier" }, "command": { "const": "linear.label.set" }, "args": { "$ref": "#/$defs/SetLabelArgs" } }
    },
    "CreateCommentEnvelope": {
      "type": "object", "additionalProperties": false,
      "required": ["protocol_version", "request_id", "turn_id", "root_issue_id", "performer_id", "command", "args"],
      "properties": { "protocol_version": { "$ref": "common.schema.json#/$defs/ProtocolVersion" }, "request_id": { "$ref": "common.schema.json#/$defs/Identifier" }, "turn_id": { "$ref": "common.schema.json#/$defs/Identifier" }, "root_issue_id": { "$ref": "common.schema.json#/$defs/Identifier" }, "performer_id": { "$ref": "common.schema.json#/$defs/OpaqueIdentifier" }, "command": { "const": "linear.comment.create" }, "args": { "$ref": "#/$defs/CreateCommentArgs" } }
    },
    "GitStatusEnvelope": {
      "type": "object", "additionalProperties": false,
      "required": ["protocol_version", "request_id", "turn_id", "root_issue_id", "performer_id", "command", "args"],
      "properties": { "protocol_version": { "$ref": "common.schema.json#/$defs/ProtocolVersion" }, "request_id": { "$ref": "common.schema.json#/$defs/Identifier" }, "turn_id": { "$ref": "common.schema.json#/$defs/Identifier" }, "root_issue_id": { "$ref": "common.schema.json#/$defs/Identifier" }, "performer_id": { "$ref": "common.schema.json#/$defs/OpaqueIdentifier" }, "command": { "const": "git.status" }, "args": { "$ref": "#/$defs/EmptyArgs" } }
    },
    "GitDiffEnvelope": {
      "type": "object", "additionalProperties": false,
      "required": ["protocol_version", "request_id", "turn_id", "root_issue_id", "performer_id", "command", "args"],
      "properties": { "protocol_version": { "$ref": "common.schema.json#/$defs/ProtocolVersion" }, "request_id": { "$ref": "common.schema.json#/$defs/Identifier" }, "turn_id": { "$ref": "common.schema.json#/$defs/Identifier" }, "root_issue_id": { "$ref": "common.schema.json#/$defs/Identifier" }, "performer_id": { "$ref": "common.schema.json#/$defs/OpaqueIdentifier" }, "command": { "const": "git.diff" }, "args": { "$ref": "#/$defs/GitDiffArgs" } }
    },
    "GitChecksEnvelope": {
      "type": "object", "additionalProperties": false,
      "required": ["protocol_version", "request_id", "turn_id", "root_issue_id", "performer_id", "command", "args"],
      "properties": { "protocol_version": { "$ref": "common.schema.json#/$defs/ProtocolVersion" }, "request_id": { "$ref": "common.schema.json#/$defs/Identifier" }, "turn_id": { "$ref": "common.schema.json#/$defs/Identifier" }, "root_issue_id": { "$ref": "common.schema.json#/$defs/Identifier" }, "performer_id": { "$ref": "common.schema.json#/$defs/OpaqueIdentifier" }, "command": { "const": "git.checks" }, "args": { "$ref": "#/$defs/GitChecksArgs" } }
    },
    "GitCommitEnvelope": {
      "type": "object", "additionalProperties": false,
      "required": ["protocol_version", "request_id", "turn_id", "root_issue_id", "performer_id", "command", "args"],
      "properties": { "protocol_version": { "$ref": "common.schema.json#/$defs/ProtocolVersion" }, "request_id": { "$ref": "common.schema.json#/$defs/Identifier" }, "turn_id": { "$ref": "common.schema.json#/$defs/Identifier" }, "root_issue_id": { "$ref": "common.schema.json#/$defs/Identifier" }, "performer_id": { "$ref": "common.schema.json#/$defs/OpaqueIdentifier" }, "command": { "const": "git.commit" }, "args": { "$ref": "#/$defs/GitCommitArgs" } }
    },
    "RootDeliverEnvelope": {
      "type": "object", "additionalProperties": false,
      "required": ["protocol_version", "request_id", "turn_id", "root_issue_id", "performer_id", "command", "args"],
      "properties": { "protocol_version": { "$ref": "common.schema.json#/$defs/ProtocolVersion" }, "request_id": { "$ref": "common.schema.json#/$defs/Identifier" }, "turn_id": { "$ref": "common.schema.json#/$defs/Identifier" }, "root_issue_id": { "$ref": "common.schema.json#/$defs/Identifier" }, "performer_id": { "$ref": "common.schema.json#/$defs/OpaqueIdentifier" }, "command": { "const": "root.deliver" }, "args": { "$ref": "#/$defs/RootDeliverArgs" } }
    },
    "CommandProblem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "sanitized_reason", "retryable", "next_steps"],
      "properties": {
        "code": { "$ref": "common.schema.json#/$defs/Identifier" },
        "sanitized_reason": { "$ref": "common.schema.json#/$defs/BoundedText" },
        "retryable": { "type": "boolean" },
        "latest_facts": { "$ref": "common.schema.json#/$defs/BoundedText" },
        "next_steps": { "type": "array", "maxItems": 8, "items": { "$ref": "common.schema.json#/$defs/ShortText" } }
      }
    },
    "AgentCommandResult": {
      "oneOf": [
        { "$ref": "#/$defs/AgentCommandSucceeded" },
        { "$ref": "#/$defs/AgentCommandConflict" },
        { "$ref": "#/$defs/AgentCommandUnconfirmed" },
        { "$ref": "#/$defs/AgentCommandRejected" },
        { "$ref": "#/$defs/AgentCommandFailed" }
      ]
    },
    "AgentCommandSucceeded": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocol_version", "request_id", "turn_id", "root_issue_id", "performer_id", "status", "summary"],
      "properties": {
        "protocol_version": { "$ref": "common.schema.json#/$defs/ProtocolVersion" },
        "request_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "turn_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "root_issue_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "performer_id": { "$ref": "common.schema.json#/$defs/OpaqueIdentifier" },
        "status": { "enum": ["applied", "already_applied", "read"] },
        "summary": { "$ref": "common.schema.json#/$defs/BoundedText" }
      }
    },
    "AgentCommandConflict": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocol_version", "request_id", "turn_id", "root_issue_id", "performer_id", "status", "problem"],
      "properties": {
        "protocol_version": { "$ref": "common.schema.json#/$defs/ProtocolVersion" },
        "request_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "turn_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "root_issue_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "performer_id": { "$ref": "common.schema.json#/$defs/OpaqueIdentifier" },
        "status": { "const": "conflict" },
        "problem": { "$ref": "#/$defs/CommandProblem" }
      }
    },
    "AgentCommandReadBackTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "issue_id"],
      "oneOf": [
        {
          "type": "object",
          "properties": { "kind": { "const": "issue" }, "write_id": false, "expected_head": false }
        },
        {
          "type": "object",
          "required": ["write_id"],
          "properties": { "kind": { "const": "comment_write" }, "expected_head": false }
        },
        {
          "type": "object",
          "required": ["expected_head"],
          "properties": { "kind": { "const": "git_head" }, "write_id": false }
        }
      ],
      "properties": {
        "kind": { "enum": ["issue", "comment_write", "git_head"] },
        "issue_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "write_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "expected_head": { "$ref": "common.schema.json#/$defs/Identifier" }
      }
    },
    "AgentCommandUnconfirmed": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocol_version", "request_id", "turn_id", "root_issue_id", "performer_id", "status", "problem", "read_back_target"],
      "properties": {
        "protocol_version": { "$ref": "common.schema.json#/$defs/ProtocolVersion" },
        "request_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "turn_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "root_issue_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "performer_id": { "$ref": "common.schema.json#/$defs/OpaqueIdentifier" },
        "status": { "const": "write_unconfirmed" },
        "problem": { "$ref": "#/$defs/CommandProblem" },
        "read_back_target": { "$ref": "#/$defs/AgentCommandReadBackTarget" }
      }
    },
    "AgentCommandRejected": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocol_version", "request_id", "turn_id", "root_issue_id", "performer_id", "status", "problem"],
      "properties": {
        "protocol_version": { "$ref": "common.schema.json#/$defs/ProtocolVersion" },
        "request_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "turn_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "root_issue_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "performer_id": { "$ref": "common.schema.json#/$defs/OpaqueIdentifier" },
        "status": { "const": "rejected" },
        "problem": { "$ref": "#/$defs/CommandProblem" }
      }
    },
    "AgentCommandFailed": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocol_version", "request_id", "turn_id", "root_issue_id", "performer_id", "status", "problem"],
      "properties": {
        "protocol_version": { "$ref": "common.schema.json#/$defs/ProtocolVersion" },
        "request_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "turn_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "root_issue_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "performer_id": { "$ref": "common.schema.json#/$defs/OpaqueIdentifier" },
        "status": { "const": "failed" },
        "problem": { "$ref": "#/$defs/CommandProblem" }
      }
    }
  },
  "$ref": "#/$defs/AgentCommandRequest"
}
