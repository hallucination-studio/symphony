{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://symphony.local/contracts/common.schema.json",
  "title": "Symphony V1 common wire primitives",
  "$defs": {
    "ProtocolVersion": {
      "type": "string",
      "const": "1"
    },
    "Identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]*$"
    },
    "OpaqueIdentifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "Timestamp": {
      "type": "string",
      "format": "date-time",
      "minLength": 20,
      "maxLength": 40
    },
    "ShortText": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "BoundedText": {
      "type": "string",
      "maxLength": 16384
    },
    "BoundedPath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4096
    },
    "NonNegativeInteger": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "LinearIssueState": {
      "type": "string",
      "enum": [
        "Draft",
        "Todo",
        "Planning",
        "Sealed",
        "Executing",
        "Verifying",
        "In Progress",
        "In Review",
        "Needs Approval",
        "Needs Info",
        "Inconclusive",
        "Escalated",
        "Approved",
        "Rejected",
        "Answered",
        "Succeeded",
        "Changes Required",
        "Done",
        "Canceled",
        "Failed"
      ]
    },
    "ProtocolError": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "category",
        "sanitized_reason",
        "retryable",
        "action_required",
        "next_action"
      ],
      "properties": {
        "code": { "$ref": "#/$defs/Identifier" },
        "category": { "$ref": "#/$defs/Identifier" },
        "sanitized_reason": { "$ref": "#/$defs/BoundedText" },
        "retryable": { "type": "boolean" },
        "action_required": { "$ref": "#/$defs/ShortText" },
        "next_action": { "$ref": "#/$defs/BoundedText" }
      }
    },
    "PageRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["limit"],
      "properties": {
        "cursor": { "$ref": "#/$defs/OpaqueIdentifier" },
        "limit": {
          "type": "integer",
          "minimum": 1,
          "maximum": 250
        }
      }
    },
    "PageInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["has_next_page"],
      "properties": {
        "has_next_page": { "type": "boolean" },
        "end_cursor": { "$ref": "#/$defs/OpaqueIdentifier" }
      }
    },
    "ProtocolEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocol_version", "request_id", "body"],
      "properties": {
        "protocol_version": { "$ref": "#/$defs/ProtocolVersion" },
        "request_id": { "$ref": "#/$defs/Identifier" },
        "body": false
      }
    }
  },
  "$ref": "#/$defs/ProtocolError"
}
