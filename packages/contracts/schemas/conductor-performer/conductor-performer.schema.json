{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://symphony.local/contracts/conductor-performer.schema.json",
  "title": "Conductor Performer Protocol V1",
  "$defs": {
    "CodexTurnSettings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model", "reasoning_effort", "is_fast_mode_enabled"],
      "properties": {
        "model": { "$ref": "common.schema.json#/$defs/ShortText" },
        "reasoning_effort": {
          "enum": ["none", "minimal", "low", "medium", "high", "xhigh"]
        },
        "is_fast_mode_enabled": { "type": "boolean" }
      }
    },
    "IssueInput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "description"],
      "properties": {
        "title": { "$ref": "common.schema.json#/$defs/BoundedText" },
        "description": { "$ref": "common.schema.json#/$defs/BoundedText" }
      }
    },
    "TreeNodeInput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["issue_id", "kind", "order", "depth", "state", "title", "description"],
      "properties": {
        "issue_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "parent_issue_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "kind": { "enum": ["work", "human"] },
        "order": { "type": "number", "minimum": -1000000000, "maximum": 1000000000 },
        "depth": { "type": "integer", "minimum": 0, "maximum": 32 },
        "state": { "$ref": "common.schema.json#/$defs/LinearIssueState" },
        "title": { "$ref": "common.schema.json#/$defs/BoundedText" },
        "description": { "$ref": "common.schema.json#/$defs/BoundedText" }
      }
    },
    "PlanTurnBody": {
      "type": "object",
      "additionalProperties": false,
      "required": ["root_issue", "current_tree"],
      "properties": {
        "root_issue": { "$ref": "#/$defs/IssueInput" },
        "current_tree": {
          "type": "array",
          "maxItems": 512,
          "items": { "$ref": "#/$defs/TreeNodeInput" }
        }
      }
    },
    "HumanInput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["human_issue_id", "status"],
      "properties": {
        "human_issue_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "status": { "enum": ["answered", "canceled"] },
        "answer": { "$ref": "common.schema.json#/$defs/BoundedText" }
      }
    },
    "WorkLeafInput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identifier", "title", "description"],
      "properties": {
        "identifier": { "$ref": "common.schema.json#/$defs/ShortText" },
        "title": { "$ref": "common.schema.json#/$defs/BoundedText" },
        "description": { "$ref": "common.schema.json#/$defs/BoundedText" }
      }
    },
    "WorkTurnBody": {
      "type": "object",
      "additionalProperties": false,
      "required": ["root_issue", "work_leaf", "human_inputs"],
      "properties": {
        "root_issue": { "$ref": "#/$defs/IssueInput" },
        "work_leaf": { "$ref": "#/$defs/WorkLeafInput" },
        "human_inputs": {
          "type": "array",
          "maxItems": 128,
          "items": { "$ref": "#/$defs/HumanInput" }
        }
      }
    },
    "RootGateTurnBody": {
      "type": "object",
      "additionalProperties": false,
      "required": ["root_issue", "complete_tree"],
      "properties": {
        "root_issue": { "$ref": "#/$defs/IssueInput" },
        "complete_tree": {
          "type": "array",
          "maxItems": 512,
          "items": { "$ref": "#/$defs/TreeNodeInput" }
        }
      }
    },
    "PlanTurnCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol_version",
        "turn_id",
        "turn_kind",
        "root_issue_id",
        "performer_profile_id",
        "codex_turn_settings",
        "turn_input_hash",
        "workspace_root",
        "started_at",
        "hard_deadline_at",
        "body"
      ],
      "properties": {
        "protocol_version": { "$ref": "common.schema.json#/$defs/ProtocolVersion" },
        "turn_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "turn_kind": { "const": "plan" },
        "root_issue_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "performer_profile_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "performer_id": { "$ref": "common.schema.json#/$defs/OpaqueIdentifier" },
        "codex_turn_settings": { "$ref": "#/$defs/CodexTurnSettings" },
        "turn_input_hash": { "$ref": "common.schema.json#/$defs/Identifier" },
        "workspace_root": { "$ref": "common.schema.json#/$defs/BoundedPath" },
        "started_at": { "$ref": "common.schema.json#/$defs/Timestamp" },
        "hard_deadline_at": { "$ref": "common.schema.json#/$defs/Timestamp" },
        "body": { "$ref": "#/$defs/PlanTurnBody" }
      }
    },
    "WorkTurnCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol_version",
        "turn_id",
        "turn_kind",
        "root_issue_id",
        "work_issue_id",
        "performer_profile_id",
        "performer_id",
        "codex_turn_settings",
        "turn_input_hash",
        "workspace_root",
        "started_at",
        "hard_deadline_at",
        "body"
      ],
      "properties": {
        "protocol_version": { "$ref": "common.schema.json#/$defs/ProtocolVersion" },
        "turn_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "turn_kind": { "const": "work" },
        "root_issue_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "work_issue_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "performer_profile_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "performer_id": { "$ref": "common.schema.json#/$defs/OpaqueIdentifier" },
        "codex_turn_settings": { "$ref": "#/$defs/CodexTurnSettings" },
        "turn_input_hash": { "$ref": "common.schema.json#/$defs/Identifier" },
        "workspace_root": { "$ref": "common.schema.json#/$defs/BoundedPath" },
        "started_at": { "$ref": "common.schema.json#/$defs/Timestamp" },
        "hard_deadline_at": { "$ref": "common.schema.json#/$defs/Timestamp" },
        "body": { "$ref": "#/$defs/WorkTurnBody" }
      }
    },
    "RootGateTurnCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol_version",
        "turn_id",
        "turn_kind",
        "root_issue_id",
        "performer_profile_id",
        "performer_id",
        "codex_turn_settings",
        "turn_input_hash",
        "workspace_root",
        "started_at",
        "hard_deadline_at",
        "body"
      ],
      "properties": {
        "protocol_version": { "$ref": "common.schema.json#/$defs/ProtocolVersion" },
        "turn_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "turn_kind": { "const": "root_gate" },
        "root_issue_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "performer_profile_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "performer_id": { "$ref": "common.schema.json#/$defs/OpaqueIdentifier" },
        "codex_turn_settings": { "$ref": "#/$defs/CodexTurnSettings" },
        "turn_input_hash": { "$ref": "common.schema.json#/$defs/Identifier" },
        "workspace_root": { "$ref": "common.schema.json#/$defs/BoundedPath" },
        "started_at": { "$ref": "common.schema.json#/$defs/Timestamp" },
        "hard_deadline_at": { "$ref": "common.schema.json#/$defs/Timestamp" },
        "body": { "$ref": "#/$defs/RootGateTurnBody" }
      }
    },
    "PerformerTurnCommand": {
      "oneOf": [
        { "$ref": "#/$defs/PlanTurnCommand" },
        { "$ref": "#/$defs/WorkTurnCommand" },
        { "$ref": "#/$defs/RootGateTurnCommand" }
      ]
    },
    "PerformerTurnUsageSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input_tokens", "cached_input_tokens", "output_tokens", "reasoning_output_tokens", "total_tokens"],
      "properties": {
        "input_tokens": { "$ref": "common.schema.json#/$defs/NonNegativeInteger" },
        "cached_input_tokens": { "$ref": "common.schema.json#/$defs/NonNegativeInteger" },
        "output_tokens": { "$ref": "common.schema.json#/$defs/NonNegativeInteger" },
        "reasoning_output_tokens": { "$ref": "common.schema.json#/$defs/NonNegativeInteger" },
        "total_tokens": { "$ref": "common.schema.json#/$defs/NonNegativeInteger" }
      }
    },
    "PlannedWorkflowNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["client_node_key", "kind", "order", "title", "description"],
      "properties": {
        "client_node_key": { "$ref": "common.schema.json#/$defs/Identifier" },
        "parent_client_node_key": { "$ref": "common.schema.json#/$defs/Identifier" },
        "kind": { "enum": ["work", "human"] },
        "order": { "type": "number", "minimum": -1000000000, "maximum": 1000000000 },
        "title": { "$ref": "common.schema.json#/$defs/BoundedText" },
        "description": { "$ref": "common.schema.json#/$defs/BoundedText" },
        "existing_issue_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "target_client_node_key": { "$ref": "common.schema.json#/$defs/Identifier" }
      }
    },
    "PlanReadyBody": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "nodes"],
      "properties": {
        "summary": { "$ref": "common.schema.json#/$defs/BoundedText" },
        "nodes": {
          "type": "array",
          "maxItems": 512,
          "items": { "$ref": "#/$defs/PlannedWorkflowNode" }
        }
      }
    },
    "SummaryBody": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary"],
      "properties": {
        "summary": { "$ref": "common.schema.json#/$defs/BoundedText" }
      }
    },
    "HumanInputRequiredBody": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sanitized_prompt"],
      "properties": {
        "sanitized_prompt": { "$ref": "common.schema.json#/$defs/BoundedText" }
      }
    },
    "RootGateFailedBody": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "findings"],
      "properties": {
        "summary": { "$ref": "common.schema.json#/$defs/BoundedText" },
        "findings": {
          "type": "array",
          "maxItems": 128,
          "items": { "$ref": "common.schema.json#/$defs/BoundedText" }
        }
      }
    },
    "TurnFailedBody": {
      "type": "object",
      "additionalProperties": false,
      "required": ["error_code", "sanitized_reason", "retryable", "action_required"],
      "properties": {
        "error_code": { "$ref": "common.schema.json#/$defs/Identifier" },
        "sanitized_reason": { "$ref": "common.schema.json#/$defs/BoundedText" },
        "retryable": { "type": "boolean" },
        "action_required": { "$ref": "common.schema.json#/$defs/BoundedText" }
      }
    },
    "TurnCanceledBody": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sanitized_reason"],
      "properties": {
        "sanitized_reason": { "$ref": "common.schema.json#/$defs/BoundedText" }
      }
    },
    "PerformerTurnResult": {
      "type": "object",
      "additionalProperties": false,
      "oneOf": [
        {
          "type": "object",
          "required": ["turn_kind", "result_kind", "performer_id", "body"],
          "properties": {
            "turn_kind": { "const": "plan" },
            "result_kind": { "const": "plan_ready" },
            "performer_id": { "$ref": "common.schema.json#/$defs/OpaqueIdentifier" },
            "body": { "$ref": "#/$defs/PlanReadyBody" }
          }
        },
        {
          "type": "object",
          "required": ["turn_kind", "result_kind", "work_issue_id", "performer_id", "body"],
          "properties": {
            "turn_kind": { "const": "work" },
            "result_kind": { "const": "work_completed" },
            "work_issue_id": { "$ref": "common.schema.json#/$defs/Identifier" },
            "performer_id": { "$ref": "common.schema.json#/$defs/OpaqueIdentifier" },
            "body": { "$ref": "#/$defs/SummaryBody" }
          }
        },
        {
          "type": "object",
          "required": ["turn_kind", "result_kind", "work_issue_id", "performer_id", "body"],
          "properties": {
            "turn_kind": { "const": "work" },
            "result_kind": { "const": "human_input_required" },
            "work_issue_id": { "$ref": "common.schema.json#/$defs/Identifier" },
            "performer_id": { "$ref": "common.schema.json#/$defs/OpaqueIdentifier" },
            "body": { "$ref": "#/$defs/HumanInputRequiredBody" }
          }
        },
        {
          "type": "object",
          "required": ["turn_kind", "result_kind", "performer_id", "body"],
          "properties": {
            "turn_kind": { "const": "root_gate" },
            "result_kind": { "const": "root_gate_passed" },
            "performer_id": { "$ref": "common.schema.json#/$defs/OpaqueIdentifier" },
            "body": { "$ref": "#/$defs/SummaryBody" }
          }
        },
        {
          "type": "object",
          "required": ["turn_kind", "result_kind", "performer_id", "body"],
          "properties": {
            "turn_kind": { "const": "root_gate" },
            "result_kind": { "const": "root_gate_failed" },
            "performer_id": { "$ref": "common.schema.json#/$defs/OpaqueIdentifier" },
            "body": { "$ref": "#/$defs/RootGateFailedBody" }
          }
        },
        {
          "type": "object",
          "required": ["turn_kind", "result_kind", "body"],
          "properties": {
            "turn_kind": { "const": "plan" },
            "result_kind": { "const": "turn_failed" },
            "body": { "$ref": "#/$defs/TurnFailedBody" }
          }
        },
        {
          "type": "object",
          "required": ["turn_kind", "result_kind", "body"],
          "properties": {
            "turn_kind": { "const": "plan" },
            "result_kind": { "const": "turn_canceled" },
            "body": { "$ref": "#/$defs/TurnCanceledBody" }
          }
        },
        {
          "type": "object",
          "required": ["turn_kind", "result_kind", "work_issue_id", "performer_id", "body"],
          "properties": {
            "turn_kind": { "const": "work" },
            "result_kind": { "enum": ["turn_failed", "turn_canceled"] },
            "work_issue_id": { "$ref": "common.schema.json#/$defs/Identifier" },
            "performer_id": { "$ref": "common.schema.json#/$defs/OpaqueIdentifier" },
            "body": {
              "oneOf": [
                { "$ref": "#/$defs/TurnFailedBody" },
                { "$ref": "#/$defs/TurnCanceledBody" }
              ]
            }
          }
        },
        {
          "type": "object",
          "required": ["turn_kind", "result_kind", "performer_id", "body"],
          "properties": {
            "turn_kind": { "const": "root_gate" },
            "result_kind": { "enum": ["turn_failed", "turn_canceled"] },
            "performer_id": { "$ref": "common.schema.json#/$defs/OpaqueIdentifier" },
            "body": {
              "oneOf": [
                { "$ref": "#/$defs/TurnFailedBody" },
                { "$ref": "#/$defs/TurnCanceledBody" }
              ]
            }
          }
        }
      ],
      "required": [
        "protocol_version",
        "turn_id",
        "turn_kind",
        "result_kind",
        "root_issue_id",
        "performer_profile_id",
        "turn_input_hash",
        "completed_at",
        "body"
      ],
      "properties": {
        "protocol_version": { "$ref": "common.schema.json#/$defs/ProtocolVersion" },
        "turn_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "turn_kind": { "enum": ["plan", "work", "root_gate"] },
        "result_kind": {
          "enum": ["plan_ready", "work_completed", "human_input_required", "root_gate_passed", "root_gate_failed", "turn_failed", "turn_canceled"]
        },
        "root_issue_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "work_issue_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "performer_profile_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "performer_id": { "$ref": "common.schema.json#/$defs/OpaqueIdentifier" },
        "turn_input_hash": { "$ref": "common.schema.json#/$defs/Identifier" },
        "completed_at": { "$ref": "common.schema.json#/$defs/Timestamp" },
        "usage": { "$ref": "#/$defs/PerformerTurnUsageSnapshot" },
        "body": {}
      }
    },
    "PerformerTurnEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocol_version", "turn_id", "root_issue_id", "sequence", "occurred_at", "body"],
      "properties": {
        "protocol_version": { "$ref": "common.schema.json#/$defs/ProtocolVersion" },
        "turn_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "root_issue_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "work_issue_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "sequence": { "$ref": "common.schema.json#/$defs/NonNegativeInteger" },
        "occurred_at": { "$ref": "common.schema.json#/$defs/Timestamp" },
        "body": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["kind"],
              "properties": { "kind": { "const": "turn_started" } }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["kind", "stage"],
              "properties": {
                "kind": { "const": "progress" },
                "stage": { "enum": ["context_loaded", "planning", "analyzing", "editing", "checking", "reviewing", "finalizing", "waiting_provider"] }
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["kind", "warning_code", "sanitized_summary"],
              "properties": {
                "kind": { "const": "warning_raised" },
                "warning_code": { "$ref": "common.schema.json#/$defs/Identifier" },
                "sanitized_summary": { "$ref": "common.schema.json#/$defs/BoundedText" }
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["kind", "usage"],
              "properties": {
                "kind": { "const": "usage_updated" },
                "usage": { "$ref": "#/$defs/PerformerTurnUsageSnapshot" }
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["kind"],
              "properties": { "kind": { "const": "heartbeat" } }
            }
          ]
        }
      }
    },
    "PerformerProfileControlMetadata": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["protocol_version", "request_id", "kind", "profile_id"],
          "properties": {
            "protocol_version": { "$ref": "common.schema.json#/$defs/ProtocolVersion" },
            "request_id": { "$ref": "common.schema.json#/$defs/Identifier" },
            "kind": { "enum": ["get_profile_status", "start_chatgpt_login"] },
            "profile_id": { "$ref": "common.schema.json#/$defs/Identifier" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["protocol_version", "request_id", "kind", "profile_id", "secret_frame_length"],
          "properties": {
            "protocol_version": { "$ref": "common.schema.json#/$defs/ProtocolVersion" },
            "request_id": { "$ref": "common.schema.json#/$defs/Identifier" },
            "kind": { "const": "set_api_key" },
            "profile_id": { "$ref": "common.schema.json#/$defs/Identifier" },
            "secret_frame_length": { "type": "integer", "minimum": 1, "maximum": 16384 }
          }
        }
      ]
    },
    "PerformerProfileControlResult": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["protocol_version", "request_id", "kind", "profile_id", "readiness"],
          "properties": {
            "protocol_version": { "$ref": "common.schema.json#/$defs/ProtocolVersion" },
            "request_id": { "$ref": "common.schema.json#/$defs/Identifier" },
            "kind": { "const": "profile_status" },
            "profile_id": { "$ref": "common.schema.json#/$defs/Identifier" },
            "readiness": { "enum": ["login-required", "ready", "invalid"] },
            "sanitized_account_label": { "$ref": "common.schema.json#/$defs/ShortText" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["protocol_version", "request_id", "kind", "profile_id"],
          "properties": {
            "protocol_version": { "$ref": "common.schema.json#/$defs/ProtocolVersion" },
            "request_id": { "$ref": "common.schema.json#/$defs/Identifier" },
            "kind": { "enum": ["login_started", "login_succeeded"] },
            "profile_id": { "$ref": "common.schema.json#/$defs/Identifier" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["protocol_version", "request_id", "kind", "profile_id", "verification_url", "user_code", "expires_at"],
          "properties": {
            "protocol_version": { "$ref": "common.schema.json#/$defs/ProtocolVersion" },
            "request_id": { "$ref": "common.schema.json#/$defs/Identifier" },
            "kind": { "const": "login_pending" },
            "profile_id": { "$ref": "common.schema.json#/$defs/Identifier" },
            "verification_url": {
              "type": "string",
              "maxLength": 2048,
              "pattern": "^https://"
            },
            "user_code": { "$ref": "common.schema.json#/$defs/ShortText" },
            "expires_at": { "$ref": "common.schema.json#/$defs/Timestamp" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["protocol_version", "request_id", "kind", "profile_id", "error"],
          "properties": {
            "protocol_version": { "$ref": "common.schema.json#/$defs/ProtocolVersion" },
            "request_id": { "$ref": "common.schema.json#/$defs/Identifier" },
            "kind": { "const": "login_failed" },
            "profile_id": { "$ref": "common.schema.json#/$defs/Identifier" },
            "error": { "$ref": "common.schema.json#/$defs/ProtocolError" }
          }
        }
      ]
    },
    "ConductorPerformerMessage": {
      "oneOf": [
        { "$ref": "#/$defs/PerformerTurnCommand" },
        { "$ref": "#/$defs/PerformerTurnResult" },
        { "$ref": "#/$defs/PerformerTurnEvent" },
        { "$ref": "#/$defs/PerformerProfileControlMetadata" },
        { "$ref": "#/$defs/PerformerProfileControlResult" }
      ]
    }
  },
  "$ref": "#/$defs/ConductorPerformerMessage"
}
