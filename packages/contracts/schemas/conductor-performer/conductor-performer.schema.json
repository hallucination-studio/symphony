{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://symphony.local/contracts/conductor-performer.schema.json",
  "title": "Conductor Performer Protocol V3",
  "$defs": {
    "AgentCommandRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "executable",
        "argv_prefix"
      ],
      "properties": {
        "executable": {
          "$ref": "common.schema.json#/$defs/ShortText"
        },
        "argv_prefix": {
          "type": "array",
          "maxItems": 16,
          "items": {
            "$ref": "common.schema.json#/$defs/ShortText"
          }
        }
      }
    },
    "AgentExecutionPolicy": {
      "type": "object",
      "additionalProperties": false,
      "$comment": "Command denylist rules take precedence over command allowlist rules.",
      "required": [
        "sandbox_mode",
        "command_allowlist",
        "command_denylist"
      ],
      "properties": {
        "sandbox_mode": {
          "enum": [
            "read_only",
            "workspace_write",
            "unrestricted"
          ],
          "default": "workspace_write"
        },
        "command_allowlist": {
          "type": "array",
          "maxItems": 64,
          "default": [],
          "items": {
            "$ref": "#/$defs/AgentCommandRule"
          }
        },
        "command_denylist": {
          "type": "array",
          "maxItems": 64,
          "default": [],
          "items": {
            "$ref": "#/$defs/AgentCommandRule"
          }
        }
      }
    },
    "CodexTurnSettings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model",
        "reasoning_effort",
        "is_fast_mode_enabled"
      ],
      "properties": {
        "model": {
          "$ref": "common.schema.json#/$defs/ShortText"
        },
        "reasoning_effort": {
          "enum": [
            "none",
            "minimal",
            "low",
            "medium",
            "high",
            "xhigh"
          ]
        },
        "is_fast_mode_enabled": {
          "type": "boolean"
        }
      }
    },
    "PerformerTurnUsageSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input_tokens",
        "cached_input_tokens",
        "output_tokens",
        "reasoning_output_tokens",
        "total_tokens"
      ],
      "properties": {
        "input_tokens": {
          "$ref": "common.schema.json#/$defs/NonNegativeInteger"
        },
        "cached_input_tokens": {
          "$ref": "common.schema.json#/$defs/NonNegativeInteger"
        },
        "output_tokens": {
          "$ref": "common.schema.json#/$defs/NonNegativeInteger"
        },
        "reasoning_output_tokens": {
          "$ref": "common.schema.json#/$defs/NonNegativeInteger"
        },
        "total_tokens": {
          "$ref": "common.schema.json#/$defs/NonNegativeInteger"
        }
      }
    },
    "OpenRootConversationCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol_version",
        "request_id",
        "performer_profile_id",
        "codex_turn_settings",
        "hard_deadline_at"
      ],
      "properties": {
        "protocol_version": {
          "$ref": "common.schema.json#/$defs/ProtocolVersion"
        },
        "request_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "performer_profile_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "codex_turn_settings": {
          "$ref": "#/$defs/CodexTurnSettings"
        },
        "hard_deadline_at": {
          "$ref": "common.schema.json#/$defs/Timestamp"
        }
      }
    },
    "RootConversationOpenedResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol_version",
        "request_id",
        "performer_profile_id",
        "performer_id",
        "completed_at"
      ],
      "properties": {
        "protocol_version": {
          "$ref": "common.schema.json#/$defs/ProtocolVersion"
        },
        "request_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "performer_profile_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "performer_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "completed_at": {
          "$ref": "common.schema.json#/$defs/Timestamp"
        }
      }
    },
    "ConversationOpenFailedResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol_version",
        "request_id",
        "performer_profile_id",
        "error_code",
        "sanitized_reason",
        "retryable",
        "completed_at"
      ],
      "properties": {
        "protocol_version": {
          "$ref": "common.schema.json#/$defs/ProtocolVersion"
        },
        "request_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "performer_profile_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "error_code": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "sanitized_reason": {
          "$ref": "common.schema.json#/$defs/BoundedText"
        },
        "retryable": {
          "type": "boolean"
        },
        "action_required": {
          "$ref": "common.schema.json#/$defs/ShortText"
        },
        "completed_at": {
          "$ref": "common.schema.json#/$defs/Timestamp"
        }
      }
    },
    "OpenRootConversationResult": {
      "oneOf": [
        {
          "$ref": "#/$defs/RootConversationOpenedResult"
        },
        {
          "$ref": "#/$defs/ConversationOpenFailedResult"
        }
      ]
    },
    "AgentRootContextPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "json",
        "markdown"
      ],
      "properties": {
        "json": {
          "type": "string",
          "maxLength": 8388608
        },
        "markdown": {
          "type": "string",
          "maxLength": 8388608
        }
      }
    },
    "RootCommandChannel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "request_fd",
        "response_fd"
      ],
      "properties": {
        "kind": {
          "const": "inherited_framed_channel"
        },
        "request_fd": {
          "type": "integer",
          "minimum": 3,
          "maximum": 1024
        },
        "response_fd": {
          "type": "integer",
          "minimum": 3,
          "maximum": 1024
        }
      }
    },
    "RootTurnLimits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_wall_time_ms",
        "max_context_bytes",
        "max_broker_calls",
        "max_mutations"
      ],
      "properties": {
        "max_wall_time_ms": {
          "type": "integer",
          "minimum": 1000,
          "maximum": 86400000
        },
        "max_context_bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 16777216
        },
        "max_broker_calls": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "max_mutations": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000
        }
      }
    },
    "RootTurnCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol_version",
        "turn_id",
        "root_issue_id",
        "performer_profile_id",
        "performer_id",
        "codex_turn_settings",
        "execution_policy",
        "root_context",
        "context_digest",
        "command_channel",
        "workspace_root",
        "started_at",
        "turn_limits"
      ],
      "properties": {
        "protocol_version": {
          "$ref": "common.schema.json#/$defs/ProtocolVersion"
        },
        "turn_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "root_issue_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "performer_profile_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "performer_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "codex_turn_settings": {
          "$ref": "#/$defs/CodexTurnSettings"
        },
        "execution_policy": {
          "$ref": "#/$defs/AgentExecutionPolicy"
        },
        "root_context": {
          "$ref": "#/$defs/AgentRootContextPayload"
        },
        "context_digest": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "command_channel": {
          "$ref": "#/$defs/RootCommandChannel"
        },
        "workspace_root": {
          "$ref": "common.schema.json#/$defs/BoundedPath"
        },
        "started_at": {
          "$ref": "common.schema.json#/$defs/Timestamp"
        },
        "turn_limits": {
          "$ref": "#/$defs/RootTurnLimits"
        }
      }
    },
    "RootTurnUsage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "wall_time_ms",
        "context_bytes",
        "provider_tokens",
        "broker_calls",
        "mutations"
      ],
      "properties": {
        "wall_time_ms": {
          "$ref": "common.schema.json#/$defs/NonNegativeInteger"
        },
        "context_bytes": {
          "$ref": "common.schema.json#/$defs/NonNegativeInteger"
        },
        "provider_tokens": {
          "$ref": "common.schema.json#/$defs/NonNegativeInteger"
        },
        "broker_calls": {
          "$ref": "common.schema.json#/$defs/NonNegativeInteger"
        },
        "mutations": {
          "$ref": "common.schema.json#/$defs/NonNegativeInteger"
        }
      }
    },
    "RootTurnResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol_version",
        "turn_id",
        "root_issue_id",
        "performer_profile_id",
        "performer_id",
        "context_digest",
        "result_kind",
        "completed_at",
        "turn_usage"
      ],
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "result_kind": {
              "const": "root_turn_completed"
            },
            "error_code": false,
            "sanitized_reason": false,
            "retryable": false,
            "action_required": false
          }
        },
        {
          "type": "object",
          "required": [
            "error_code",
            "sanitized_reason"
          ],
          "properties": {
            "result_kind": {
              "const": "root_conversation_unavailable"
            },
            "error_code": {
              "enum": [
                "conversation_not_found",
                "conversation_unrecoverable"
              ]
            },
            "bounded_summary": false,
            "yield_reason": false,
            "retryable": false,
            "action_required": false
          }
        },
        {
          "type": "object",
          "required": [
            "error_code",
            "sanitized_reason",
            "retryable"
          ],
          "properties": {
            "result_kind": {
              "const": "root_turn_failed"
            },
            "bounded_summary": false,
            "yield_reason": false
          }
        },
        {
          "type": "object",
          "required": [
            "sanitized_reason"
          ],
          "properties": {
            "result_kind": {
              "const": "root_turn_canceled"
            },
            "bounded_summary": false,
            "yield_reason": false,
            "error_code": false,
            "retryable": false,
            "action_required": false
          }
        }
      ],
      "properties": {
        "protocol_version": {
          "$ref": "common.schema.json#/$defs/ProtocolVersion"
        },
        "turn_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "root_issue_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "performer_profile_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "performer_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "context_digest": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "result_kind": {
          "enum": [
            "root_turn_completed",
            "root_conversation_unavailable",
            "root_turn_failed",
            "root_turn_canceled"
          ]
        },
        "completed_at": {
          "$ref": "common.schema.json#/$defs/Timestamp"
        },
        "usage": {
          "$ref": "#/$defs/PerformerTurnUsageSnapshot"
        },
        "turn_usage": {
          "$ref": "#/$defs/RootTurnUsage"
        },
        "bounded_summary": {
          "$ref": "common.schema.json#/$defs/BoundedText"
        },
        "yield_reason": {
          "enum": [
            "command_limit_reached",
            "waiting_human",
            "delivered",
            "agent_finished"
          ]
        },
        "error_code": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "sanitized_reason": {
          "$ref": "common.schema.json#/$defs/BoundedText"
        },
        "retryable": {
          "type": "boolean"
        },
        "action_required": {
          "$ref": "common.schema.json#/$defs/ShortText"
        }
      }
    },
    "RootTurnEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol_version",
        "turn_id",
        "root_issue_id",
        "performer_profile_id",
        "performer_id",
        "context_digest",
        "sequence",
        "occurred_at",
        "body"
      ],
      "properties": {
        "protocol_version": {
          "$ref": "common.schema.json#/$defs/ProtocolVersion"
        },
        "turn_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "root_issue_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "performer_profile_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "performer_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "context_digest": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "sequence": {
          "$ref": "common.schema.json#/$defs/NonNegativeInteger"
        },
        "occurred_at": {
          "$ref": "common.schema.json#/$defs/Timestamp"
        },
        "body": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "kind"
              ],
              "properties": {
                "kind": {
                  "enum": [
                    "protocol_ready",
                    "turn_started",
                    "heartbeat",
                    "turn_completed"
                  ]
                }
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "kind",
                "stage"
              ],
              "properties": {
                "kind": {
                  "const": "progress"
                },
                "stage": {
                  "enum": [
                    "context_loaded",
                    "resuming_conversation",
                    "running_provider",
                    "waiting_broker",
                    "finalizing"
                  ]
                }
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "kind",
                "code",
                "sanitized_summary"
              ],
              "properties": {
                "kind": {
                  "enum": [
                    "warning",
                    "error"
                  ]
                },
                "code": {
                  "$ref": "common.schema.json#/$defs/Identifier"
                },
                "sanitized_summary": {
                  "$ref": "common.schema.json#/$defs/BoundedText"
                }
              }
            }
          ]
        }
      }
    },
    "PerformerProfileControlMetadata": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "protocol_version",
            "request_id",
            "kind",
            "profile_id"
          ],
          "properties": {
            "protocol_version": {
              "$ref": "common.schema.json#/$defs/ProtocolVersion"
            },
            "request_id": {
              "$ref": "common.schema.json#/$defs/Identifier"
            },
            "kind": {
              "enum": [
                "get_profile_status",
                "start_chatgpt_login"
              ]
            },
            "profile_id": {
              "$ref": "common.schema.json#/$defs/Identifier"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "protocol_version",
            "request_id",
            "kind",
            "profile_id",
            "secret_frame_length"
          ],
          "properties": {
            "protocol_version": {
              "$ref": "common.schema.json#/$defs/ProtocolVersion"
            },
            "request_id": {
              "$ref": "common.schema.json#/$defs/Identifier"
            },
            "kind": {
              "const": "set_api_key"
            },
            "profile_id": {
              "$ref": "common.schema.json#/$defs/Identifier"
            },
            "secret_frame_length": {
              "type": "integer",
              "minimum": 1,
              "maximum": 16384
            }
          }
        }
      ]
    },
    "PerformerProfileControlResult": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "protocol_version",
            "request_id",
            "kind",
            "profile_id",
            "readiness"
          ],
          "properties": {
            "protocol_version": {
              "$ref": "common.schema.json#/$defs/ProtocolVersion"
            },
            "request_id": {
              "$ref": "common.schema.json#/$defs/Identifier"
            },
            "kind": {
              "const": "profile_status"
            },
            "profile_id": {
              "$ref": "common.schema.json#/$defs/Identifier"
            },
            "readiness": {
              "enum": [
                "login-required",
                "ready",
                "invalid"
              ]
            },
            "sanitized_account_label": {
              "$ref": "common.schema.json#/$defs/ShortText"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "protocol_version",
            "request_id",
            "kind",
            "profile_id"
          ],
          "properties": {
            "protocol_version": {
              "$ref": "common.schema.json#/$defs/ProtocolVersion"
            },
            "request_id": {
              "$ref": "common.schema.json#/$defs/Identifier"
            },
            "kind": {
              "enum": [
                "login_started",
                "login_succeeded"
              ]
            },
            "profile_id": {
              "$ref": "common.schema.json#/$defs/Identifier"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "protocol_version",
            "request_id",
            "kind",
            "profile_id",
            "verification_url",
            "user_code",
            "expires_at"
          ],
          "properties": {
            "protocol_version": {
              "$ref": "common.schema.json#/$defs/ProtocolVersion"
            },
            "request_id": {
              "$ref": "common.schema.json#/$defs/Identifier"
            },
            "kind": {
              "const": "login_pending"
            },
            "profile_id": {
              "$ref": "common.schema.json#/$defs/Identifier"
            },
            "verification_url": {
              "type": "string",
              "maxLength": 2048,
              "pattern": "^https://"
            },
            "user_code": {
              "$ref": "common.schema.json#/$defs/ShortText"
            },
            "expires_at": {
              "$ref": "common.schema.json#/$defs/Timestamp"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "protocol_version",
            "request_id",
            "kind",
            "profile_id",
            "error"
          ],
          "properties": {
            "protocol_version": {
              "$ref": "common.schema.json#/$defs/ProtocolVersion"
            },
            "request_id": {
              "$ref": "common.schema.json#/$defs/Identifier"
            },
            "kind": {
              "const": "login_failed"
            },
            "profile_id": {
              "$ref": "common.schema.json#/$defs/Identifier"
            },
            "error": {
              "$ref": "common.schema.json#/$defs/ProtocolError"
            }
          }
        }
      ]
    },
    "ConductorPerformerMessage": {
      "oneOf": [
        {
          "$ref": "#/$defs/OpenRootConversationCommand"
        },
        {
          "$ref": "#/$defs/OpenRootConversationResult"
        },
        {
          "$ref": "#/$defs/RootTurnCommand"
        },
        {
          "$ref": "#/$defs/RootTurnResult"
        },
        {
          "$ref": "#/$defs/RootTurnEvent"
        },
        {
          "$ref": "#/$defs/PerformerProfileControlMetadata"
        },
        {
          "$ref": "#/$defs/PerformerProfileControlResult"
        }
      ]
    }
  },
  "$ref": "#/$defs/ConductorPerformerMessage"
}
