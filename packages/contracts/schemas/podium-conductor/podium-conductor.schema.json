{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://symphony.local/contracts/podium-conductor.schema.json",
  "title": "Podium Conductor Protocol V1",
  "$defs": {
    "RepositoryContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository_handle",
        "canonical_path",
        "base_branch"
      ],
      "properties": {
        "repository_handle": {
          "$ref": "common.schema.json#/$defs/OpaqueIdentifier"
        },
        "canonical_path": {
          "$ref": "common.schema.json#/$defs/BoundedPath"
        },
        "base_branch": {
          "$ref": "common.schema.json#/$defs/ShortText"
        }
      }
    },
    "ConductorHandshakeCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "binding_id",
        "conductor_id",
        "conductor_short_hash",
        "instance_id",
        "linear_installation_id",
        "organization_id",
        "repository"
      ],
      "properties": {
        "kind": {
          "const": "conductor_handshake"
        },
        "binding_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "conductor_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "conductor_short_hash": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "instance_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "linear_installation_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "organization_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "repository": {
          "$ref": "#/$defs/RepositoryContext"
        }
      }
    },
    "ConductorHandshakeResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "binding_id", "instance_id", "observed_at"],
      "properties": {
        "kind": { "const": "conductor_handshake_ack" },
        "binding_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "instance_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "observed_at": { "$ref": "common.schema.json#/$defs/Timestamp" }
      }
    },
    "ShutdownConductorCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "binding_id",
        "instance_id",
        "deadline_at"
      ],
      "properties": {
        "kind": {
          "const": "shutdown_conductor"
        },
        "binding_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "instance_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "deadline_at": {
          "$ref": "common.schema.json#/$defs/Timestamp"
        }
      }
    },
    "ShutdownConductorResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "const": "shutdown_conductor_ack"
        }
      }
    },
    "LinearIssueNodeSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "issue_id",
        "identifier",
        "project_id",
        "state",
        "order",
        "depth",
        "title",
        "description",
        "is_archived",
        "updated_at"
      ],
      "properties": {
        "issue_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "identifier": {
          "$ref": "common.schema.json#/$defs/ShortText"
        },
        "project_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "parent_issue_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "state": {
          "$ref": "common.schema.json#/$defs/LinearIssueState"
        },
        "order": {
          "type": "number",
          "minimum": -1000000000,
          "maximum": 1000000000
        },
        "depth": {
          "type": "integer",
          "minimum": 0,
          "maximum": 32
        },
        "title": {
          "$ref": "common.schema.json#/$defs/BoundedText"
        },
        "description": {
          "$ref": "common.schema.json#/$defs/BoundedText"
        },
        "is_archived": {
          "type": "boolean"
        },
        "managed_marker": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "node_kind": {
          "enum": [
            "work",
            "human"
          ]
        },
        "human_kind": {
          "enum": [
            "plan_approval",
            "planned_input",
            "runtime_input"
          ]
        },
        "origin": {
          "enum": [
            "user",
            "symphony"
          ]
        },
        "completed_input_hash": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "target_issue_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "updated_at": {
          "$ref": "common.schema.json#/$defs/Timestamp"
        }
      }
    },
    "LinearPriority": {
      "type": "string",
      "enum": [
        "urgent",
        "high",
        "normal",
        "low",
        "no_priority"
      ]
    },
    "LinearBlockerSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_issue_id",
        "target_issue_id",
        "target_state"
      ],
      "properties": {
        "source_issue_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "target_issue_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "target_state": {
          "$ref": "common.schema.json#/$defs/LinearIssueState"
        }
      }
    },
    "RootIssueSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "issue",
        "is_delegated_to_symphony",
        "priority",
        "blockers",
        "root_conductor_labels",
        "root_managed_comments"
      ],
      "properties": {
        "issue": {
          "$ref": "#/$defs/LinearIssueNodeSnapshot"
        },
        "is_delegated_to_symphony": {
          "type": "boolean"
        },
        "priority": {
          "$ref": "#/$defs/LinearPriority"
        },
        "blockers": {
          "type": "array",
          "maxItems": 512,
          "items": {
            "$ref": "#/$defs/LinearBlockerSnapshot"
          }
        },
        "root_conductor_labels": {
          "type": "array",
          "maxItems": 1,
          "items": {
            "$ref": "#/$defs/ConductorPool"
          }
        },
        "root_managed_comments": {
          "type": "array",
          "maxItems": 2,
          "items": {
            "$ref": "#/$defs/LinearCommentSnapshot"
          }
        }
      }
    },
    "LinearProjectSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_id",
        "organization_id",
        "name",
        "updated_at"
      ],
      "properties": {
        "project_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "organization_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "name": {
          "$ref": "common.schema.json#/$defs/ShortText"
        },
        "updated_at": {
          "$ref": "common.schema.json#/$defs/Timestamp"
        }
      }
    },
    "ConductorPool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "conductor_short_hash"
      ],
      "properties": {
        "conductor_short_hash": {
          "$ref": "common.schema.json#/$defs/Identifier"
        }
      }
    },
    "ResolvedConductorProject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project",
        "conductor_short_hash",
        "conductor_pool"
      ],
      "properties": {
        "project": {
          "$ref": "#/$defs/LinearProjectSnapshot"
        },
        "conductor_short_hash": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "conductor_pool": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "items": {
            "$ref": "#/$defs/ConductorPool"
          }
        }
      }
    },
    "ProjectResolutionResult": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "resolved_project"
          ],
          "properties": {
            "kind": {
              "const": "resolved"
            },
            "resolved_project": {
              "$ref": "#/$defs/ResolvedConductorProject"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "const": "unbound"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "error"
          ],
          "properties": {
            "kind": {
              "const": "conductor_project_ambiguous"
            },
            "error": {
              "$ref": "common.schema.json#/$defs/ProtocolError"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "error"
          ],
          "properties": {
            "kind": {
              "const": "conductor_project_label_conflict"
            },
            "error": {
              "$ref": "common.schema.json#/$defs/ProtocolError"
            }
          }
        }
      ]
    },
    "LinearCommentSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "comment_id",
        "issue_id",
        "body",
        "updated_at"
      ],
      "properties": {
        "comment_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "issue_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "body": {
          "$ref": "common.schema.json#/$defs/BoundedText"
        },
        "managed_marker": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "updated_at": {
          "$ref": "common.schema.json#/$defs/Timestamp"
        }
      }
    },
    "ResolveConductorProjectQuery": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "binding_id",
        "conductor_short_hash"
      ],
      "properties": {
        "kind": {
          "const": "resolve_conductor_project"
        },
        "binding_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "conductor_short_hash": {
          "$ref": "common.schema.json#/$defs/Identifier"
        }
      }
    },
    "ListRootIssuesQuery": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "binding_id",
        "project_id",
        "page"
      ],
      "properties": {
        "kind": {
          "const": "list_root_issues"
        },
        "binding_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "project_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "page": {
          "$ref": "common.schema.json#/$defs/PageRequest"
        }
      }
    },
    "RootIssuesPageResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "items",
        "page_info"
      ],
      "properties": {
        "kind": {
          "const": "root_issues_page"
        },
        "items": {
          "type": "array",
          "maxItems": 250,
          "items": {
            "$ref": "#/$defs/RootIssueSnapshot"
          }
        },
        "page_info": {
          "$ref": "common.schema.json#/$defs/PageInfo"
        }
      }
    },
    "WorkflowStatusCategory": {
      "enum": [
        "backlog",
        "unstarted",
        "started",
        "completed",
        "canceled"
      ]
    },
    "WorkflowStatusSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status_id",
        "name",
        "category",
        "position"
      ],
      "properties": {
        "status_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "name": {
          "$ref": "common.schema.json#/$defs/ShortText"
        },
        "category": {
          "$ref": "#/$defs/WorkflowStatusCategory"
        },
        "position": {
          "type": "number",
          "minimum": -1000000000,
          "maximum": 1000000000
        }
      }
    },
    "WorkflowIssueSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "issue_id",
        "identifier",
        "project_id",
        "status_id",
        "status_name",
        "status_category",
        "status_position",
        "order",
        "depth",
        "title",
        "description",
        "is_archived",
        "remote_version",
        "updated_at"
      ],
      "properties": {
        "issue_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "identifier": {
          "$ref": "common.schema.json#/$defs/ShortText"
        },
        "project_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "parent_issue_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "status_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "status_name": {
          "$ref": "common.schema.json#/$defs/ShortText"
        },
        "status_category": {
          "$ref": "#/$defs/WorkflowStatusCategory"
        },
        "status_position": {
          "type": "number",
          "minimum": -1000000000,
          "maximum": 1000000000
        },
        "order": {
          "type": "number",
          "minimum": -1000000000,
          "maximum": 1000000000
        },
        "depth": {
          "type": "integer",
          "minimum": 0,
          "maximum": 32
        },
        "title": {
          "$ref": "common.schema.json#/$defs/BoundedText"
        },
        "description": {
          "$ref": "common.schema.json#/$defs/BoundedText"
        },
        "is_archived": {
          "type": "boolean"
        },
        "managed_marker": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "issue_kind": {
          "enum": [
            "root",
            "cycle",
            "plan",
            "work",
            "verify",
            "human"
          ]
        },
        "remote_version": {
          "$ref": "common.schema.json#/$defs/OpaqueIdentifier"
        },
        "updated_at": {
          "$ref": "common.schema.json#/$defs/Timestamp"
        }
      }
    },
    "WorkflowCommentSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "comment_id",
        "issue_id",
        "body",
        "remote_version",
        "updated_at"
      ],
      "properties": {
        "comment_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "issue_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "body": {
          "$ref": "common.schema.json#/$defs/BoundedText"
        },
        "managed_marker": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "remote_version": {
          "$ref": "common.schema.json#/$defs/OpaqueIdentifier"
        },
        "updated_at": {
          "$ref": "common.schema.json#/$defs/Timestamp"
        }
      }
    },
    "WorkflowRelationSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "relation_id",
        "relation_kind",
        "source_issue_id",
        "target_issue_id"
      ],
      "properties": {
        "relation_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "relation_kind": {
          "enum": [
            "blocks",
            "blocked_by",
            "triggered_by"
          ]
        },
        "source_issue_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "target_issue_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        }
      }
    },
    "WorkflowRootTreeSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "root_issue_id",
        "status_catalog",
        "issues",
        "comments",
        "relations",
        "observed_at"
      ],
      "properties": {
        "root_issue_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "status_catalog": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "items": {
            "$ref": "#/$defs/WorkflowStatusSnapshot"
          }
        },
        "issues": {
          "type": "array",
          "minItems": 1,
          "maxItems": 512,
          "items": {
            "$ref": "#/$defs/WorkflowIssueSnapshot"
          }
        },
        "comments": {
          "type": "array",
          "maxItems": 4096,
          "items": {
            "$ref": "#/$defs/WorkflowCommentSnapshot"
          }
        },
        "relations": {
          "type": "array",
          "maxItems": 1024,
          "items": {
            "$ref": "#/$defs/WorkflowRelationSnapshot"
          }
        },
        "observed_at": {
          "$ref": "common.schema.json#/$defs/Timestamp"
        }
      }
    },
    "GetWorkflowIssueTreeQuery": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "binding_id",
        "conductor_short_hash",
        "expected_project_id",
        "root_issue_id"
      ],
      "properties": {
        "kind": {
          "const": "get_workflow_issue_tree"
        },
        "binding_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "conductor_short_hash": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "expected_project_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "root_issue_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        }
      }
    },
    "WorkflowIssueTreeResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "tree"
      ],
      "properties": {
        "kind": {
          "const": "workflow_issue_tree"
        },
        "tree": {
          "$ref": "#/$defs/WorkflowRootTreeSnapshot"
        }
      }
    },
    "WorkflowMutationTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_issue_id",
        "expected_remote_version"
      ],
      "properties": {
        "target_issue_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "expected_remote_version": {
          "$ref": "common.schema.json#/$defs/OpaqueIdentifier"
        },
        "expected_status_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "expected_parent_issue_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "expected_managed_marker": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "expected_is_archived": {
          "type": "boolean"
        }
      }
    },
    "CreateWorkflowIssueCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "binding_id",
        "write_id",
        "conductor_short_hash",
        "expected_project_id",
        "root_issue_id",
        "expected_root_remote_version",
        "parent_expected_remote_version",
        "parent_expected_status_id",
        "parent_issue_id",
        "issue_kind",
        "title",
        "description",
        "status_id",
        "managed_marker"
      ],
      "properties": {
        "kind": {
          "const": "create_workflow_issue"
        },
        "binding_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "write_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "conductor_short_hash": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "expected_project_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "root_issue_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "expected_root_remote_version": {
          "$ref": "common.schema.json#/$defs/OpaqueIdentifier"
        },
        "parent_expected_remote_version": {
          "$ref": "common.schema.json#/$defs/OpaqueIdentifier"
        },
        "parent_expected_status_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "parent_issue_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "issue_kind": {
          "enum": [
            "cycle",
            "plan",
            "work",
            "verify",
            "human"
          ]
        },
        "title": {
          "$ref": "common.schema.json#/$defs/BoundedText"
        },
        "description": {
          "$ref": "common.schema.json#/$defs/BoundedText"
        },
        "status_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "managed_marker": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "order": {
          "type": "number",
          "minimum": -1000000000,
          "maximum": 1000000000
        }
      }
    },
    "UpdateWorkflowIssueCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "binding_id",
        "write_id",
        "conductor_short_hash",
        "expected_project_id",
        "root_issue_id",
        "expected_root_remote_version",
        "target",
        "status_id",
        "title",
        "description"
      ],
      "properties": {
        "kind": {
          "const": "update_workflow_issue"
        },
        "binding_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "write_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "conductor_short_hash": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "expected_project_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "root_issue_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "expected_root_remote_version": {
          "$ref": "common.schema.json#/$defs/OpaqueIdentifier"
        },
        "target": {
          "$ref": "#/$defs/WorkflowMutationTarget"
        },
        "status_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "title": {
          "$ref": "common.schema.json#/$defs/BoundedText"
        },
        "description": {
          "$ref": "common.schema.json#/$defs/BoundedText"
        }
      }
    },
    "AppendWorkflowCommentCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "binding_id",
        "write_id",
        "conductor_short_hash",
