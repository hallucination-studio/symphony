{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://symphony.local/contracts/podium-client.schema.json",
  "title": "Podium Client Protocol V1",
  "$defs": {
    "AgentCommandRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "executable",
        "argv_prefix"
      ],
      "properties": {
        "executable": {
          "$ref": "common.schema.json#/$defs/ShortText"
        },
        "argv_prefix": {
          "type": "array",
          "maxItems": 16,
          "items": {
            "$ref": "common.schema.json#/$defs/ShortText"
          }
        }
      }
    },
    "AgentExecutionPolicy": {
      "type": "object",
      "additionalProperties": false,
      "$comment": "Command denylist rules take precedence over command allowlist rules.",
      "required": [
        "sandbox_mode",
        "command_allowlist",
        "command_denylist"
      ],
      "properties": {
        "sandbox_mode": {
          "enum": [
            "read_only",
            "workspace_write",
            "unrestricted"
          ],
          "default": "workspace_write"
        },
        "command_allowlist": {
          "type": "array",
          "maxItems": 64,
          "default": [],
          "items": {
            "$ref": "#/$defs/AgentCommandRule"
          }
        },
        "command_denylist": {
          "type": "array",
          "maxItems": 64,
          "default": [],
          "items": {
            "$ref": "#/$defs/AgentCommandRule"
          }
        }
      }
    },
    "RepositorySelection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository_handle",
        "display_name",
        "base_branch"
      ],
      "properties": {
        "repository_handle": {
          "$ref": "common.schema.json#/$defs/OpaqueIdentifier"
        },
        "display_name": {
          "$ref": "common.schema.json#/$defs/ShortText"
        },
        "base_branch": {
          "$ref": "common.schema.json#/$defs/ShortText"
        }
      }
    },
    "CodexTurnSettings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model",
        "reasoning_effort",
        "is_fast_mode_enabled"
      ],
      "properties": {
        "model": {
          "$ref": "common.schema.json#/$defs/ShortText"
        },
        "reasoning_effort": {
          "enum": [
            "none",
            "minimal",
            "low",
            "medium",
            "high",
            "xhigh"
          ]
        },
        "is_fast_mode_enabled": {
          "type": "boolean"
        }
      }
    },
    "ConnectLinearCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "const": "connect_linear"
        }
      }
    },
    "ReconnectLinearCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "const": "reconnect_linear"
        }
      }
    },
    "CreateConductorCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "project_id",
        "repository"
      ],
      "properties": {
        "kind": {
          "const": "create_conductor"
        },
        "project_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "repository": {
          "$ref": "#/$defs/RepositorySelection"
        }
      }
    },
    "StartConductorCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "conductor_id"
      ],
      "properties": {
        "kind": {
          "const": "start_conductor"
        },
        "conductor_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        }
      }
    },
    "StopConductorCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "conductor_id"
      ],
      "properties": {
        "kind": {
          "const": "stop_conductor"
        },
        "conductor_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        }
      }
    },
    "RestartConductorCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "conductor_id"
      ],
      "properties": {
        "kind": {
          "const": "restart_conductor"
        },
        "conductor_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        }
      }
    },
    "GetPerformerProfilesQuery": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "conductor_id"
      ],
      "properties": {
        "kind": {
          "const": "get_performer_profiles"
        },
        "conductor_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        }
      }
    },
    "GetPerformerProfileStatusQuery": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "conductor_id",
        "profile_id"
      ],
      "properties": {
        "kind": {
          "const": "get_performer_profile_status"
        },
        "conductor_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "profile_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        }
      }
    },
    "CreatePerformerProfileCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "conductor_id",
        "display_name",
        "backend_kind",
        "authentication_method",
        "codex_turn_settings",
        "execution_policy"
      ],
      "properties": {
        "kind": {
          "const": "create_performer_profile"
        },
        "conductor_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "display_name": {
          "$ref": "common.schema.json#/$defs/ShortText"
        },
        "backend_kind": {
          "const": "codex"
        },
        "authentication_method": {
          "enum": [
            "chatgpt",
            "api_key"
          ]
        },
        "codex_turn_settings": {
          "$ref": "#/$defs/CodexTurnSettings"
        },
        "execution_policy": {
          "$ref": "#/$defs/AgentExecutionPolicy"
        }
      }
    },
    "UpdatePerformerProfileCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "conductor_id",
        "profile_id",
        "display_name",
        "codex_turn_settings",
        "execution_policy"
      ],
      "properties": {
        "kind": {
          "const": "update_performer_profile"
        },
        "conductor_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "profile_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "display_name": {
          "$ref": "common.schema.json#/$defs/ShortText"
        },
        "codex_turn_settings": {
          "$ref": "#/$defs/CodexTurnSettings"
        },
        "execution_policy": {
          "$ref": "#/$defs/AgentExecutionPolicy"
        }
      }
    },
    "StartCodexChatGPTLoginCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "conductor_id",
        "profile_id"
      ],
      "properties": {
        "kind": {
          "const": "start_codex_chatgpt_login"
        },
        "conductor_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "profile_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        }
      }
    },
    "SetCodexApiKeyCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "conductor_id",
        "profile_id",
        "secret_frame_length"
      ],
      "properties": {
        "kind": {
          "const": "set_codex_api_key"
        },
        "conductor_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "profile_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "secret_frame_length": {
          "type": "integer",
          "minimum": 1,
          "maximum": 16384
        }
      }
    },
    "ActivatePerformerProfileCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "conductor_id",
        "profile_id"
      ],
      "properties": {
        "kind": {
          "const": "activate_performer_profile"
        },
        "conductor_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "profile_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        }
      }
    },
    "LinearConnectionView": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "observed_at"
      ],
      "properties": {
        "status": {
          "enum": [
            "disconnected",
            "connected",
            "reconnect_required",
            "failed"
          ]
        },
        "workspace_name": {
          "$ref": "common.schema.json#/$defs/ShortText"
        },
        "observed_at": {
          "$ref": "common.schema.json#/$defs/Timestamp"
        },
        "error": {
          "$ref": "common.schema.json#/$defs/ProtocolError"
        }
      }
    },
    "PerformerProfileSummaryView": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile_id",
        "display_name",
        "authentication_method",
        "codex_turn_settings",
        "execution_policy",
        "readiness",
        "is_active",
        "observed_at"
      ],
      "properties": {
        "profile_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "display_name": {
          "$ref": "common.schema.json#/$defs/ShortText"
        },
        "authentication_method": {
          "enum": [
            "chatgpt",
            "api_key"
          ]
        },
        "codex_turn_settings": {
          "$ref": "#/$defs/CodexTurnSettings"
        },
        "execution_policy": {
          "$ref": "#/$defs/AgentExecutionPolicy"
        },
        "readiness": {
          "enum": [
            "login-required",
            "ready",
            "invalid"
          ]
        },
        "is_active": {
          "type": "boolean"
        },
        "sanitized_account_label": {
          "$ref": "common.schema.json#/$defs/ShortText"
        },
        "observed_at": {
          "$ref": "common.schema.json#/$defs/Timestamp"
        }
      }
    },
    "PerformerProfileDetailView": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary"
      ],
      "properties": {
        "summary": {
          "$ref": "#/$defs/PerformerProfileSummaryView"
        },
        "sanitized_last_error": {
          "$ref": "common.schema.json#/$defs/BoundedText"
        }
      }
    },
    "ConductorSummaryView": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "conductor_id",
        "display_name",
        "status",
        "observed_at"
      ],
      "properties": {
        "conductor_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "display_name": {
          "$ref": "common.schema.json#/$defs/ShortText"
        },
        "status": {
          "enum": [
            "online",
            "offline"
          ]
        },
        "project_name": {
          "$ref": "common.schema.json#/$defs/ShortText"
        },
        "repository_display_name": {
          "$ref": "common.schema.json#/$defs/ShortText"
        },
        "base_branch": {
          "$ref": "common.schema.json#/$defs/ShortText"
        },
        "observed_at": {
          "$ref": "common.schema.json#/$defs/Timestamp"
        }
      }
    },
    "ProjectSummaryView": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_id",
        "name",
        "observed_at"
      ],
      "properties": {
        "project_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "name": {
          "$ref": "common.schema.json#/$defs/ShortText"
        },
        "observed_at": {
          "$ref": "common.schema.json#/$defs/Timestamp"
        }
      }
    },
    "DesktopOverviewView": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "linear_connection",
        "projects",
        "conductors",
        "recent_logs",
        "observed_at"
      ],
      "properties": {
        "linear_connection": {
          "$ref": "#/$defs/LinearConnectionView"
        },
        "projects": {
          "type": "array",
          "maxItems": 512,
          "items": {
            "$ref": "#/$defs/ProjectSummaryView"
          }
        },
        "conductors": {
          "type": "array",
          "maxItems": 64,
          "items": {
            "$ref": "#/$defs/ConductorSummaryView"
          }
        },
        "observed_at": {
          "$ref": "common.schema.json#/$defs/Timestamp"
        },
        "recent_logs": {
          "type": "array",
          "maxItems": 64,
          "items": {
            "$ref": "#/$defs/RuntimeLogView"
          }
        }
      }
    },
    "ConductorDetailView": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "profiles",
        "logs"
      ],
      "properties": {
        "summary": {
          "$ref": "#/$defs/ConductorSummaryView"
        },
        "profiles": {
          "type": "array",
          "maxItems": 64,
          "items": {
            "$ref": "#/$defs/PerformerProfileSummaryView"
          }
        },
        "logs": {
          "type": "array",
          "maxItems": 128,
          "items": {
            "$ref": "#/$defs/RuntimeLogView"
          }
        }
      }
    },
    "GetDesktopOverviewQuery": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "const": "get_desktop_overview"
        }
      }
    },
    "GetConductorDetailQuery": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "conductor_id"
      ],
      "properties": {
        "kind": {
          "const": "get_conductor_detail"
        },
        "conductor_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        }
      }
    },
    "PodiumClientBody": {
      "oneOf": [
        {
          "$ref": "#/$defs/ConnectLinearCommand"
        },
        {
          "$ref": "#/$defs/ReconnectLinearCommand"
        },
        {
          "$ref": "#/$defs/CreateConductorCommand"
        },
        {
          "$ref": "#/$defs/StartConductorCommand"
        },
        {
          "$ref": "#/$defs/StopConductorCommand"
        },
        {
          "$ref": "#/$defs/RestartConductorCommand"
        },
        {
          "$ref": "#/$defs/GetPerformerProfilesQuery"
        },
        {
          "$ref": "#/$defs/GetPerformerProfileStatusQuery"
        },
        {
          "$ref": "#/$defs/CreatePerformerProfileCommand"
        },
        {
          "$ref": "#/$defs/UpdatePerformerProfileCommand"
        },
        {
          "$ref": "#/$defs/StartCodexChatGPTLoginCommand"
        },
        {
          "$ref": "#/$defs/SetCodexApiKeyCommand"
        },
        {
          "$ref": "#/$defs/ActivatePerformerProfileCommand"
        },
        {
          "$ref": "#/$defs/GetDesktopOverviewQuery"
        },
        {
          "$ref": "#/$defs/GetConductorDetailQuery"
        },
        {
          "$ref": "#/$defs/DesktopOverviewView"
        },
        {
          "$ref": "#/$defs/ConductorDetailView"
        },
        {
          "$ref": "#/$defs/LinearConnectionView"
        },
        {
          "$ref": "#/$defs/ConductorSummaryView"
        },
        {
          "$ref": "#/$defs/ProjectSummaryView"
        },
        {
          "$ref": "#/$defs/PerformerProfileSummaryView"
        },
        {
          "$ref": "#/$defs/PerformerProfileDetailView"
        },
        {
          "$ref": "common.schema.json#/$defs/ProtocolError"
        },
        {
          "$ref": "#/$defs/LinearAuthorizationStartedResult"
        },
        {
          "$ref": "#/$defs/ConductorCreatedResult"
        },
        {
          "$ref": "#/$defs/ConductorCommandResult"
        }
      ]
    },
    "PodiumClientMessage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol_version",
        "request_id",
        "body"
      ],
      "properties": {
        "protocol_version": {
          "$ref": "common.schema.json#/$defs/ProtocolVersion"
        },
        "request_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "body": {
          "$ref": "#/$defs/PodiumClientBody"
        }
      }
    },
    "RuntimeLogView": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_kind",
        "summary",
        "occurred_at"
      ],
      "properties": {
        "event_kind": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "summary": {
          "$ref": "common.schema.json#/$defs/BoundedText"
        },
        "occurred_at": {
          "$ref": "common.schema.json#/$defs/Timestamp"
        }
      }
    },
    "LinearAuthorizationStartedResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "attempt_id"
      ],
      "properties": {
        "kind": {
          "const": "linear_authorization_started"
        },
        "attempt_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        }
      }
    },
    "ConductorCreatedResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "conductor_id"
      ],
      "properties": {
        "kind": {
          "const": "conductor_created"
        },
        "conductor_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        }
      }
    },
    "ConductorCommandResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "conductor_id",
        "command_kind"
      ],
      "properties": {
        "kind": {
          "const": "conductor_command_completed"
        },
        "conductor_id": {
          "$ref": "common.schema.json#/$defs/Identifier"
        },
        "command_kind": {
          "enum": [
            "start_conductor",
            "stop_conductor",
            "restart_conductor"
          ]
        }
      }
    }
  },
  "$ref": "#/$defs/PodiumClientMessage"
}
