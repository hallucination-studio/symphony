{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Podium",
  "version": "0.1.0",
  "identifier": "dev.symphony.podium",
  "build": {
    "beforeDevCommand": "cd ../web && npm run dev",
    "beforeBuildCommand": "cd ../web && npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../../src/podium/static"
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' http://127.0.0.1:8090"
    },
    "windows": [
      {
        "label": "main",
        "title": "Podium",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 620
      }
    ]
  },
  "bundle": {
    "active": true,
    "resources": {
      "../../src/podium/resources/linear-application.json": "resources/linear-application.json"
    },
    "externalBin": [
      "binaries/podium",
      "binaries/conductor",
      "binaries/performer"
    ],
    "icon": ["icons/icon.png"],
    "targets": "all"
  }
}
